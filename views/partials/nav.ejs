<nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #001f4d;">
  <div class="container-fluid">
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>

        <% if (typeof visibleCategories !== 'undefined') { %>
          <% visibleCategories.forEach(category => { %>
            <li class="nav-item">
              <a class="nav-link" href="/<%= category.name.toLowerCase() %>"><%= category.name %></a>
            </li>
          <% }) %>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/events">Events</a></li>
          <li class="nav-item"><a class="nav-link" href="/sports">Sports</a></li>
          <li class="nav-item"><a class="nav-link" href="/opinion">Opinion</a></li>
          <li class="nav-item"><a class="nav-link" href="/podcast">Podcast</a></li>
          <li class="nav-item"><a class="nav-link" href="/vacancies">Vacancies</a></li>
        <% } %>
      </ul>
      <div class="search-container" style="display: flex; align-items: center;">
        <input
          type="search"
          class="search-input"
          id="search"
          placeholder="Search news..."
          aria-label="Search news"
          style="flex: 1; padding: 5px 10px; border: 1px solid #ccc; border-radius: 4px 0 0 4px; outline: none;"
        />
        <button
          class="search-button"
          type="button"
          aria-label="Search"
          style="background-color: #0056b3; color: #fff; border: none; padding: 6px 12px; border-radius: 0 4px 4px 0; cursor: pointer;"
        >
          <i class="fas fa-search"></i>
        </button>
      </div>
    </div>
  </div>
</nav>
