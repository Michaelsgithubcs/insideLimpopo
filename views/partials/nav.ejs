<!-- Menu styles - must be after Bootstrap CSS -->
<link rel="stylesheet" href="/css/mobile-menu-fix.css">
<link rel="stylesheet" href="/css/custom-mobile-nav.css">
<link rel="stylesheet" href="/css/mobile-menu-final-fix.css">
<link rel="stylesheet" href="/css/desktop-nav-fixes.css">
<link rel="stylesheet" href="/css/desktop-nav-overrides.css">
<link rel="stylesheet" href="/css/mobile-menu-debug.css">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark" style="background-color: #001f4d !important;">
  <div class="container-fluid">
    <!-- Brand / Logo -->
    <a class="navbar-brand fw-bold" href="/">
      <img src="/assets/logo/InsideLimpopoLogoTransparent.png" alt="Logo" width="35" height="35" class="d-inline-block align-text-top">
      Inside Limpopo
    </a>

    <!-- Hamburger button for mobile -->
    <button class="navbar-toggler" type="button" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navbar items -->
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <!-- Home link -->
        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>

        <!-- Dynamic categories -->
        <% if (typeof visibleCategories !== 'undefined') { %>
          <% visibleCategories.forEach(category => { %>
            <% 
              const excluded = ['sports', 'news', 'events', 'podcast', 'opinion', 'vacancies']; 
              const catName = category.name.toLowerCase();
            %>
            <% if (excluded.includes(catName)) { %>
              <!-- Main category -->
              <li class="nav-item">
                <a class="nav-link" href="/<%= catName %>"><%= category.name %></a>
              </li>
            <% } else { %>
              <!-- Custom/added category -->
              <li class="nav-item">
                <a class="nav-link" href="/articles/added/<%= catName %>"><%= category.name %></a>
              </li>
            <% } %>
          <% }) %>
        <% } else { %>
          <!-- Fallback static categories -->
          <li class="nav-item"><a class="nav-link" href="/events">Events</a></li>
          <li class="nav-item"><a class="nav-link" href="/sports">Sports</a></li>
          <li class="nav-item"><a class="nav-link" href="/opinion">Opinion</a></li>
          <li class="nav-item"><a class="nav-link" href="/podcast">Podcast</a></li>
          <li class="nav-item"><a class="nav-link" href="/vacancies">Vacancies</a></li>
        <% } %>
      </ul>

      <!-- Search box -->
      <div class="search-container" style="display: flex; align-items: center;">
        <input
          type="search"
          class="search-input"
          id="search"
          placeholder="Search news..."
          aria-label="Search news"
          style="flex: 1; padding: 5px 10px; border: 1px solid #ccc; border-radius: 4px 0 0 4px; outline: none;"
        />
        <button
          class="search-button"
          type="button"
          aria-label="Search"
          style="background-color: #0056b3; color: #fff; border: none; padding: 6px 12px; border-radius: 0 4px 4px 0; cursor: pointer;"
        >
          <i class="fas fa-search"></i>
        </button>
      </div>
    </div>
  </div>
</nav>
<script src="/scripts/mobile-menu.js"></script>
<script src="/scripts/responsive-nav-handler.js"></script>
<script src="/scripts/breaking-news-ticker.js"></script>
<script src="/scripts/nav-link-debug.js"></script>
