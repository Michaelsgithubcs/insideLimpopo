<!DOCTYPE html>
<html lang="en">
  <%- include('./partials/head.ejs') %>

  <body>
    <!-- Header Section -->
    <%- include('./partials/header.ejs') %>
    <%- include('./partials/nav.ejs') %>

    <!-- Main Content -->
    <main>
      <!-- Sports News Section -->
      <section id="sports-news">
        <h2>Sports News</h2>
        <p>
          Stay updated with the latest sports news, scores, and match highlights
          from around Limpopo.
        </p>
      </section>

      <!-- Featured Sports Events Section -->
      <section id="featured-events">
        <h2>Featured Sports Events</h2>
        <p>
          Discover the top upcoming sports events and matches that you don't
          want to miss.
        </p>

        <!-- Sports Event Cards -->
        <div class="sports-section">
          <div class="sports-card">
            <img
              src="./assets/sportsimages/football.jpeg"
              alt="Football Match"
            />
            <h3>Football: Championship Final</h3>
            <p>
              Get ready for the grand final of the football championship. Don't
              miss the action!
            </p>
          </div>

          <div class="sports-card">
            <img
              src="./assets/sportsimages/basketball.jpeg"
              alt="Basketball Game"
            />
            <h3>Basketball: League Playoffs</h3>
            <p>
              The league playoffs are heating up. Catch the live games and see
              which team will rise to the top.
            </p>
          </div>

          <div class="sports-card">
            <img
              src="./assets/sportsimages/tennis.jpeg"
              alt="Tennis Tournament"
            />
            <h3>Tennis: International Tournament</h3>
            <p>
              Top tennis players are facing off in this exciting international
              tournament.
            </p>
          </div>
        </div>
      </section>

      <!-- Featured Sports Teams Section -->
      <section id="sports-teams">
        <h2>Featured Sports Teams</h2>
        <p>
          Learn about the most popular and successful sports teams in various
          disciplines.
        </p>

        <div class="sports-section">
          <div class="sports-card">
            <img
              src="./assets/sportsimages/footballteam.jpeg"
              alt="Football Team"
            />
            <h3>Magezi United</h3>
            <p>
              One of the most successful football clubs in the world, with a
              rich history of achievements.
            </p>
          </div>

          <div class="sports-card">
            <img
              src="./assets/sportsimages/basketballteam.jpeg"
              alt="Basketball Team"
            />
            <h3>Mojapelo`s Riders</h3>
            <p>
              Known for their iconic players and legendary performances, the
              Lakers continue to dominate the NBA.
            </p>
          </div>

          <div class="sports-card">
            <img
              src="./assets/sportsimages/tennisteam.jpeg"
              alt="Tennis Team"
            />
            <h3>Mogano`s Hot-Flurs</h3>
            <p>
              Mogano`s Hot-Flurs is a powerhouse in the world of tennis, with
              numerous Grand Slam titles under her belt.
            </p>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer Section -->
    <%- include('./partials/footer.ejs') %>

    <script src="./js/scipt.js"></script>
  </body>
</html>
