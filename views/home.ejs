          </div>
        </div>
      </div>`;
        });
        techNews.innerHTML = html;
      };

      // Fetch and display news on page load
      window.addEventListener("load", async () => {
        const breakingNews = await fetchData("general", 1);
        add_breakingNews(breakingNews);

        const topHeadlines = await fetchData("general", 20);
        add_topNews(topHeadlines);

        const sportsData = await fetchData("sports", 5);
        add_sportsNews(sportsData);

        const businessData = await fetchData("business", 5);
        add_businessNews(businessData);

        const techData = await fetchData("technology", 5);
        add_techNews(techData);
      });
