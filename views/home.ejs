    <script>
      let breakingImg = document.querySelector("#breakingImg");
      let breakingNews_title = document.querySelector("#breakingNews .title");
      let breakingNews_desc = document.querySelector(
        "#breakingNews .description"
      );
      let topNews = document.querySelector(".topNews");
      let sportsNews = document.querySelector("#sportsNews .newsBox");
      let businessNews = document.querySelector("#businessNews .newsBox");
      let techNews = document.querySelector("#techNews .newsBox");

      const API_KEY = "b58aae20fe8c8763d71035f682ca20ad"; 

      // Fetch data from GNews API
      const fetchData = async (category, pageSize) => {
        const url = `https://gnews.io/api/v4/top-headlines?category=${category}&max=${pageSize}&lang=en&country=za&apikey=${API_KEY}`;
        try {
          const response = await fetch(url);
          if (!response.ok) {
            throw new Error(`HTTP error! Status: ${response.status}`);
          }
          const data = await response.json();
          return data.articles; // GNews API returns articles in the `articles` property
        } catch (error) {
          console.error("Error fetching news:", error);
          return [];
        }
      };

      // Add breaking news
      const add_breakingNews = (data) => {
        if (data.length > 0) {
          breakingImg.innerHTML = `<img src=${
            data[0].image || "https://via.placeholder.com/400"
          } alt="image">`;
          breakingNews_title.innerHTML = `<a href=${data[0].url} target="_blank"><h2>${data[0].title}</h2></a>`;
          breakingNews_desc.innerHTML = `${data[0].description}`;
        } else {
          breakingImg.innerHTML = `<img src="https://via.placeholder.com/400" alt="image">`;
          breakingNews_title.innerHTML = `<h2>No breaking news available</h2>`;
          breakingNews_desc.innerHTML = `Check back later for updates.`;
        }
      };

      // Add top news
      const add_topNews = (data) => {
        let html = "";
        data.forEach((element) => {
          const title =
            element.title.length > 100
              ? element.title.slice(0, 100) + "..."
              : element.title;
          html += `
      <div class="news">
        <div class="img">
          <img src=${
            element.image || "https://via.placeholder.com/400"
          } alt="image">
        </div>
        <div class="text">
          <div class="title">
            <a href=${element.url} target="_blank"><p>${title}</p></a>
          </div>
        </div>
      </div>`;
        });
        topNews.innerHTML = html;
      };

      // Add sports news
      const add_sportsNews = (data) => {
        let html = "";
        data.forEach((element) => {
          const title =
            element.title.length > 100
              ? element.title.slice(0, 100) + "..."
