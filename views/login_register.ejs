<!DOCTYPE html>
<html lang="en">
  <%- include('./partials/head.ejs') %>
  <body class="auth-page">
    <!-- Main Section -->
    <main class="auth-main">
      <section class="auth-container">
        <!-- Auth Card -->
        <div class="auth-card">
          <!-- Form Toggle -->
          <div class="form-toggle">
            <button class="toggle-btn active" id="show-login">Sign In</button>
            <button class="toggle-btn" id="show-register">
              Create Account
            </button>
          </div>

          <!-- Login Form -->
          <div class="auth-form" id="login-form">
            <div class="auth-header">
              <h2>Welcome Back</h2>
              <p>Sign in to access your account</p>
            </div>

            <form action="/login" method="POST" class="auth-form-content">
              <div class="input-container">
                <input type="text" id="username" name="username" required />
                <label for="username">Email</label>
              </div>

              <div class="input-container">
                <input
                  type="password"
                  id="login-password"
                  name="password"
                  required
                />
                <label for="login-password">Password</label>
                <button
                  class="show-password"
                  type="button"
                  role="switch"
                  aria-label="Show password"
                  aria-checked="false"
                >
                  Show
                </button>
              </div>

              <div class="form-options">
                <label class="remember-me">
                  <input
                    type="checkbox"
                    value="remember-me"
                    id="rememberMe"
                    onclick="isRememberMe()"
                  />Remember Me
                </label>
                <a href="#forgot-password" class="forgot-password"
                  >Forgot password?</a
                >
              </div>

              <div class="submit-container">
                <input type="submit" value="Sign In" class="auth-button" />
              </div>

              <div class="social-auth">
                <p class="divider"><span>or continue with</span></p>
                <div class="social-buttons">
                  <button type="button" class="social-button google">
                    <i class="fab fa-google"></i> Google
                  </button>
                  <button type="button" class="social-button facebook">
                    <i class="fab fa-facebook-f"></i> Facebook
                  </button>
                </div>
              </div>

              <p class="auth-footer">
                Don't have an account?
                <a href="#" id="switch-to-register">Sign up</a>
              </p>
            </form>
          </div>

          <!-- Register Form (Hidden by default) -->
          <div class="auth-form hidden" id="register-form">
            <div class="auth-header">
              <h2>Create Account</h2>
              <p>Join our community today</p>
            </div>

            <form action="/register" method="POST" class="auth-form-content">
              <!-- Name Fields -->
              <div class="name-fields">
                <div class="input-container">
                  <input
                    type="text"
                    id="first_name"
                    name="first_name"
                    required
                  />
                  <label for="first_name">First Name</label>
                </div>

                <div class="input-container">
                  <input type="text" id="last_name" name="last_name" required />
                  <label for="last_name">Last Name</label>
                </div>
              </div>

              <div class="input-container">
                <input type="text" id="reg-username" name="username" required />
                <label for="reg-username">Username</label>
              </div>

              <div class="input-container">
                <input type="email" id="email" name="email" required />
                <label for="email">Email Address</label>
              </div>

              <!-- Role Selection -->
              <div class="input-container select-container">
                <select id="role" name="role" required>
                  <option value="" disabled selected>Select your role</option>
                  <option value="user">User</option>
                  <option value="subscriber">Subscriber</option>
                  <option value="admin">Admin</option>
                </select>
                <label for="role">Account Type</label>
              </div>

              <div class="input-container">
                <input
                  type="password"
                  id="reg-password"
                  name="password"
                  required
                />
                <label for="reg-password">Password</label>
                <button
                  class="show-password"
                  type="button"
                  role="switch"
                  aria-label="Show password"
                  aria-checked="false"
                >
                  Show
                </button>
              </div>

              <div class="password-requirements">
                <p class="requirement hidden" id="length">
                  Must be at least 8 characters
                </p>
                <p class="requirement hidden" id="lowercase">
                  Must contain a lowercase letter
                </p>
                <p class="requirement hidden" id="uppercase">
                  Must contain an uppercase letter
                </p>
                <p class="requirement hidden" id="number">
                  Must contain a number
                </p>
                <p class="requirement hidden" id="characters">
                  Must contain a special character (#.?!@$%^&*-)
                </p>
              </div>

              <div class="input-container">
                <input
                  type="password"
                  id="repeat-password"
                  name="repeat_password"
                  required
                />
                <label for="repeat-password">Repeat Password</label>
                <button
                  class="show-password"
                  type="button"
                  role="switch"
                  aria-label="Show password"
                  aria-checked="false"
                >
                  Show
                </button>
              </div>

              <div class="password-requirements">
                <p class="requirement hidden" id="match">
                  Passwords must match
                </p>
              </div>

              <div class="terms-group">
                <label class="terms-checkbox">
                  <input type="checkbox" name="terms" required />
                  <span
                    >I agree to the <a href="#terms">Terms of Service</a> and
                    <a href="#privacy">Privacy Policy</a></span
                  >
                </label>
              </div>

              <div class="submit-container">
                <input
                  type="submit"
                  value="Create Account"
                  class="auth-button"
                  id="register-submit"
                  disabled
                />
              </div>

              <p class="auth-footer">
                Already have an account?
                <a href="#" id="switch-to-login">Sign in</a>
              </p>
            </form>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer Section -->
    <%- include('./partials/footer.ejs') %>

    <!-- Scripts -->
    <script
      src="https://kit.fontawesome.com/a076d05399.js"
      crossorigin="anonymous"
    ></script>
    <script>
      // Form toggle functionality
      document.addEventListener("DOMContentLoaded", function () {
        const showLogin = document.getElementById("show-login");
        const showRegister = document.getElementById("show-register");
        const loginForm = document.getElementById("login-form");
        const registerForm = document.getElementById("register-form");
        const switchToRegister = document.getElementById("switch-to-register");
        const switchToLogin = document.getElementById("switch-to-login");

        function checkInitialForm() {
          if (window.location.pathname.endsWith('/register')) {
            showRegisterForm();
          } else {
            showLoginForm();
          }
        }

        function showLoginForm() {
          showLogin.classList.add("active");
          showRegister.classList.remove("active");
          loginForm.classList.remove("hidden");
          registerForm.classList.add("hidden");
          history.pushState(null, null, '/login');
        }

        function showRegisterForm() {
          showRegister.classList.add("active");
          showLogin.classList.remove("active");
          registerForm.classList.remove("hidden");
          loginForm.classList.add("hidden");
        }

        checkInitialForm();

        if (showLogin && showRegister && loginForm && registerForm) {
          showLogin.addEventListener("click", function (e) {
            e.preventDefault();
            showLoginForm();
          });

          showRegister.addEventListener("click", function (e) {
            e.preventDefault();
            showRegisterForm();
          });

          if (switchToRegister) {
            switchToRegister.addEventListener("click", function (e) {
              e.preventDefault();
              showRegisterForm();
            });
          }

          if (switchToLogin) {
            switchToLogin.addEventListener("click", function (e) {
              e.preventDefault();
              showLoginForm();
            });
          }
        } else {
          console.error("Could not find all required elements for form toggle");
        }
        window.addEventListener('popstate', function() {
        checkInitialForm();
      });
      });

     

      // Password toggle functionality
      document.querySelectorAll(".show-password").forEach((button) => {
        button.addEventListener("click", function () {
          const input = this.parentElement.querySelector(
            'input[type="password"], input[type="text"]'
          );
          if (input.type === "password") {
            input.type = "text";
            this.innerText = "hide";
            this.setAttribute("aria-label", "hide password");
            this.setAttribute("aria-checked", "true");
          } else {
            input.type = "password";
            this.innerText = "show";
            this.setAttribute("aria-label", "show password");
            this.setAttribute("aria-checked", "false");
          }
        });
      });

      // Remember me
      const rmCheck = document.getElementById("rememberMe"),
        emailInput = document.getElementById("username");

      if (localStorage.checkbox && localStorage.checkbox !== "") {
        rmCheck.setAttribute("checked", "checked");
        emailInput.value = localStorage.username;
      } else {
        rmCheck.removeAttribute("checked");
        emailInput.value = "";
      }

      function isRememberMe() {
        if (rmCheck.checked && emailInput.value !== "") {
          localStorage.username = emailInput.value;
          localStorage.checkbox = rmCheck.value;
        } else {
          localStorage.username = "";
          localStorage.checkbox = "";
        }
      }

      // Password validation
      const password = document.getElementById("reg-password");
      const confirmPassword = document.getElementById("repeat-password");
      const registerSubmit = document.getElementById("register-submit");
      const matchPassword = document.getElementById("match");

      const updateRequirement = (id, valid) => {
        const requirement = document.getElementById(id);
        requirement.classList.remove("hidden");
        if (valid) {
          requirement.classList.add("valid");
          requirement.classList.remove("error");
        } else {
          requirement.classList.add("error");
          requirement.classList.remove("valid");
        }
      };

      if (password) {
        password.addEventListener("input", (event) => {
          const value = event.target.value;
          updateRequirement("length", value.length >= 8);
          updateRequirement("lowercase", /[a-z]/.test(value));
          updateRequirement("uppercase", /[A-Z]/.test(value));
          updateRequirement("number", /\d/.test(value));
          updateRequirement("characters", /[#.?!@$%^&*-]/.test(value));
          handleFormValidation();
        });
      }

      if (confirmPassword) {
        confirmPassword.addEventListener("input", (event) => {
          const value = event.target.value;
          if (value.length && value !== password.value) {
            matchPassword.classList.remove("hidden");
            matchPassword.classList.add("error");
            matchPassword.classList.remove("valid");
          } else if (value.length && value === password.value) {
            matchPassword.classList.remove("hidden");
            matchPassword.classList.add("valid");
            matchPassword.classList.remove("error");
          } else {
            matchPassword.classList.add("hidden");
          }
          handleFormValidation();
        });
      }

      const handleFormValidation = () => {
        if (!password || !confirmPassword) return;

        const value = password.value;
        const confirmValue = confirmPassword.value;

        if (
          value.length >= 8 &&
          /[a-z]/.test(value) &&
          /[A-Z]/.test(value) &&
          /\d/.test(value) &&
          /[#.?!@$%^&*-]/.test(value) &&
          value === confirmValue
        ) {
          registerSubmit.removeAttribute("disabled");
          return true;
        }

        registerSubmit.setAttribute("disabled", true);
        return false;
      };

      // Initialize input labels
      document.querySelectorAll(".input-container input").forEach((input) => {
        input.addEventListener("blur", function () {
          if (this.value) {
            this.classList.add("is-valid");
          } else {
            this.classList.remove("is-valid");
          }
        });
      });

      // Initialize select labels
      document.querySelectorAll(".select-container select").forEach((select) => {
        select.addEventListener("change", function() {
          if (this.value) {
            this.classList.add("is-valid");
          } else {
            this.classList.remove("is-valid");
          }
        });
      });
    </script>
  </body>
</html>